{
  "name": "youtube-music-bot",
  "version": "0.2.0",
  "description": "YouTube Music 點歌機器人 WebUI",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:frontend && npm run build",
    "start": "NODE_ENV=production bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__",
    "test:watch": "bun test src/__tests__ --watch"
  },
  "dependencies": {
    "hono": "^4.6.17",
    "ws": "^8.19.0",
    "youtube-ext": "^1.1.25",
    "youtubei.js": "^16.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
